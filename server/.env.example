# 服务端口（Railway 会自动注入 PORT，无需手动设置）
# PORT=3001

# 管理员密码（首次启动时创建 admin 账号使用，之后修改此值不影响已有账号）
ADMIN_PASSWORD=admin123

# 允许跨域的前端地址（逗号分隔，Vercel 部署后填入实际地址）
# 例如: CORS_ORIGIN=https://photobooth.vercel.app
CORS_ORIGIN=

# 数据库文件路径（Railway 挂载持久化存储卷时设置，默认使用项目内 data/ 目录）
# 例如: DB_PATH=/data/photobooth.db
DB_PATH=
